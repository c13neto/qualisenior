# ==========================================
# 🛑 SEGURANÇA E CREDENCIAIS (CRÍTICO)
# ==========================================
.env
.env.*
!.env.example
*.pem
*.key

# ==========================================
# 📦 DEPENDÊNCIAS (BACKEND E FRONTEND)
# ==========================================
node_modules/
/backend/node_modules/
/frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# 🗄️ BANCO DE DADOS E INFRAESTRUTURA
# ==========================================
# Ignora os volumes do Docker com os dados reais do Postgres
/backend/database/db_data/
/backend/database/pgdata/
*.sqlite
*.sqlite-journal

# ==========================================
# ⚙️ PRISMA (ARQUIVOS GERADOS)
# ==========================================
# O Prisma Client deve ser gerado no servidor, não comitado
/backend/generated/
/generated/

# ==========================================
# 📝 LOGS E ARQUIVOS TEMPORÁRIOS DO PROJETO
# ==========================================
# Ignora os logs do seu script bash e arquivos de debug
output_*.log
output_prisma-express.log
structure.txt
*.log

# ==========================================
# 🖥️ FRONTEND (BUILDS)
# ==========================================
# Ignora a pasta de build final do frontend (Vite/React/Next)
/frontend/dist/
/frontend/build/
/frontend/.next/
/frontend/out/

# ==========================================
# 🍎 SISTEMA OPERACIONAL E EDITORES
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/