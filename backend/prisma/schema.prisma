generator client {
  provider = "prisma-client"
  output   = "../generated/prisma/"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SYSADMIN
  ADMIN
  FISIO
  PACIENTE
}

enum UserStatus {
  ATIVO
  INATIVO
  PENDENTE
}

enum SessionStatus {
  PROGRESSO
  CONCLUIDO
  CANCELADO
  PENDENTE
}

enum Specialization {
  MOBILIDADE_EQUILIBRIO
  MARCHA
  RESPIRATORIO
  UROGINECOLOGIA
  GERONTOLOGIA
}

enum Contract {
  QUALISENIOR
  TRIAGE
  CME
}

enum Senior {
  ESTAGIARIO
  JUNIOR
  PLENO
  SENIOR
}

enum PaymentStatus {
  A_PAGAR
  PAGO
  ATRASADO
  CANCELADO
}

enum Type {
  FIXO
  VARIAVEL
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  telephone      String          @unique
  password       String
  role           Role
  seniority      Senior?
  specialization Specialization?
  status         UserStatus      @default(ATIVO)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  whoCreated     String
  whoUpdated     String[]

  sessionAsFisio   Session[] @relation("FisioSession")
  sessionAsPatient Session[] @relation("PatientSession")
  reportsAsFisio   Report[]  @relation("FisioReports")
}

model Session {
  id             String         @id @default(uuid())
  daysWeek       String[]
  hoursWork      String[]
  contract       Contract
  specialization Specialization
  dayStart       DateTime
  dayEnd         DateTime
  status         SessionStatus  @default(PROGRESSO)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  whoCreated     String
  whoUpdated     String[]

  fisioId String
  fisio   User   @relation("FisioSession", fields: [fisioId], references: [id], onDelete: Cascade)

  patientId String
  patient   User   @relation("PatientSession", fields: [patientId], references: [id], onDelete: Cascade)

  reportAsSession Report[] @relation("SessionReports")
}

model Report {
  id          String        @id @default(uuid())
  title       String
  description String
  date        DateTime
  status      SessionStatus @default(CONCLUIDO)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  whoCreated  String
  whoUpdated  String[]

  fisioId String
  fisio   User   @relation("FisioReports", fields: [fisioId], references: [id], onDelete: Cascade)

  sessionId String
  session   Session @relation("SessionReports", fields: [sessionId], references: [id], onDelete: Cascade)
}

model Cost {
  id          String        @id @default(uuid())
  name        String
  value       Decimal       @db.Decimal(10, 2)
  type        Type
  dateInitial DateTime
  dateFinal   DateTime?
  status      PaymentStatus @default(A_PAGAR)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  whoCreated  String
  whoUpdated  String[]
}
